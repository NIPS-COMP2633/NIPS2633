<%# 

This is the login page for MRU username and password.
Upon submission, the form will send the users password and username to the script in:
``` 
NIPS/app/services/mru_auth.rb
````
( Via post "login_mru/authenticate" )

"mru_auth.rb" currently prints the contents into the log space (terminal).

 %>
 
<!DOCTYPE html>
<html lang="en">

<head>

    <%# google font imports %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Doto:wght@100..900&family=Nabla&display=swap" rel="stylesheet">
    <%# end %>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyMru Login</title>
    <%= stylesheet_link_tag "login_mru" %>
</head>

<body>
    <!-- Main container for the login form -->
    <div class="login-container">

        <!-- Heading for the form -->
        <h2>MRU Login</h2>
        
        <!-- The actual form element -->
        <%= form_with url: login_mru_authenticate_path, method: :post, local: true do |form| %>

            <!-- username input field group -->
            <div class="form-group">
                <label for="username">Username</label>
                <%= form.text_field :username, id: "username", placeholder: "Enter your username", required: true %>
            </div>

            <!-- Password input field group -->
            <div class="form-group">
                <label for="password">Password</label>
                <%= form.password_field :password, id: "password", placeholder: "Enter your password", required: true %>
            </div>

            <!-- Submit button -->
            <%= form.submit "Login", class: "submit-btn" %>
        <% end %>
    </div>
</body>

</html>
