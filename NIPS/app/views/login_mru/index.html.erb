<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyMru Login</title>
    <style>
        /* Reset default browser styles and set up base styling */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            /* Create a centered layout with a pleasant background */
            font-family: monospace;
            background: linear-gradient(135deg, #667eeace 0%, #764ba2bb 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* The main container that holds our login form */
        .login-container {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 400px;
        }

        /* Style the heading */
        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
        }

        /* Group each input field with its label */
        .form-group {
            margin-bottom: 20px;
        }

        /* Style the labels above each input */
        label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-weight: 500;
        }

        /* Style all input fields (email and password) */
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 12px;
            border: 2px solid #3d3d3d;
            border-radius: 5px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        /* Change border color when user clicks/focuses on input */
        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #667eea;
        }

        /* Style the submit button */
        .submit-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
        }

        /* Add a subtle effect when hovering over the button */
        .submit-btn:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body>
    <!-- Main container for the login form -->
    <div class="login-container">
        <!-- Heading for the form -->
        <h2>MRU Login</h2>
        
        <!-- The actual form element -->
        <form>
            <!-- Email input field group -->
            <div class="form-group">
                <label for="email">Username</label>
                <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    placeholder="Enter your email"
                    required
                >
            </div>

            <!-- Password input field group -->
            <div class="form-group">
                <label for="password">Password</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    placeholder="Enter your password"
                    required
                >
            </div>

            <!-- Submit button -->
            <button type="submit" class="submit-btn">Login</button>
        </form>
    </div>
</body>
</html>
