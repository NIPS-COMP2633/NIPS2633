#!/bin/bash
# Pre-commit hook to auto-update README with current file structure

# Change to the repository root
cd "$(git rev-parse --show-toplevel)" || exit 1

# Run the structure update script
bash .automations/git_hooks/bash/structure_update.sh

# Check if README.md was modified
if git diff --name-only | grep -q "README.md"; then
    echo "File structure in README.md has been updated automatically"
    # Stage the updated README
    git add README.md
fi

exit 0
